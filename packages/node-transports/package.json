{
  "name": "emdash-smtp-node-transports",
  "version": "0.3.1",
  "description": "Internal Node.js transport adapters for emdash-smtp. End users should install emdash-smtp.",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm build"
  },
  "keywords": [
    "emdash",
    "emdash-plugin",
    "smtp",
    "email",
    "nodemailer"
  ],
  "author": "Mason James",
  "dependencies": {
    "emdash-smtp-core": "0.3.1",
    "nodemailer": "^6.10.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masonjames/emdash-smtp.git",
    "directory": "packages/node-transports"
  },
  "homepage": "https://github.com/masonjames/emdash-smtp#readme",
  "bugs": {
    "url": "https://github.com/masonjames/emdash-smtp/issues"
  }
}
