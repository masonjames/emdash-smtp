{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "emdash": ["../emdash/packages/core"],
      "emdash-smtp-core": ["./packages/core/src/index.ts"],
      "emdash-smtp-node-transports": ["./packages/node-transports/src/index.ts"]
    }
  }
}
